{
  "info": {
    "name": "HustleHub Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health - Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/auth/register",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "register"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"John Doe\",\n  \"username\": \"john_doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"StrongPass123\",\n  \"skills\": [\"python\", \"dsa\"],\n  \"level\": \"intermediate\"\n}"
        }
      }
    },
    {
      "name": "Auth - Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const data = pm.response.json();",
              "if (data && data.access_token) {",
              "  pm.collectionVariables.set('token', data.access_token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"StrongPass123\"\n}"
        }
      }
    },
    {
      "name": "User - Suggestions",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/user/suggestions?limit=10",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "user",
            "suggestions"
          ],
          "query": [
            {
              "key": "limit",
              "value": "10"
            }
          ]
        }
      }
    },
    {
      "name": "User - Follow",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/user/follow",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "user",
            "follow"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"target_user_id\": \"<USER_ID>\"\n}"
        }
      }
    },
    {
      "name": "Video - Upload",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/video/upload",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "video",
            "upload"
          ]
        },
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "caption",
              "value": "My coding reel",
              "type": "text"
            },
            {
              "key": "tags",
              "value": "python,dsa,interview",
              "type": "text"
            },
            {
              "key": "file",
              "type": "file",
              "src": ""
            }
          ]
        }
      }
    },
    {
      "name": "Video - Feed",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/video/feed?mode=following&limit=20",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "video",
            "feed"
          ],
          "query": [
            {
              "key": "mode",
              "value": "following"
            },
            {
              "key": "limit",
              "value": "20"
            }
          ]
        }
      }
    },
    {
      "name": "Video - Like",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/video/like",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "video",
            "like"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"video_id\": \"<VIDEO_ID>\"\n}"
        }
      }
    },
    {
      "name": "Discover - Users",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/discover/users?limit=12",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "discover",
            "users"
          ],
          "query": [
            {
              "key": "limit",
              "value": "12"
            }
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "token",
      "value": ""
    }
  ]
}
