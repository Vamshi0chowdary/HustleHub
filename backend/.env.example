APP_ENV=production
APP_NAME=HustleHub API
APP_VERSION=1.0.0
API_PREFIX=/api/v1
JWT_SECRET=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hustlehub?retryWrites=true&w=majority
MONGODB_DB_NAME=hustlehub
MONGODB_SERVER_SELECTION_TIMEOUT_MS=30000
MONGODB_CONNECT_TIMEOUT_MS=30000
MONGODB_SOCKET_TIMEOUT_MS=30000
MONGODB_HEARTBEAT_FREQUENCY_MS=10000
MONGODB_MAX_POOL_SIZE=100
MONGODB_MIN_POOL_SIZE=2
MONGODB_MAX_IDLE_TIME_MS=45000
MONGODB_CONNECT_RETRIES=8
MONGODB_RETRY_DELAY_SECONDS=2
CORS_ORIGINS=https://your-frontend-url.vercel.app
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
