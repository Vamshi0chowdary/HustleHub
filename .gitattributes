# Normalize text files to LF in the repository
* text=auto eol=lf

# Keep Windows script files with CRLF checkouts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.7z binary
*.mp4 binary
*.mov binary
*.avi binary
*.onnx binary
*.h5 binary
*.pt binary
*.pth binary
*.pkl binary
*.joblib binary
